# ── TimeSync environment configuration ──
# Copy this file to .env and fill in your values.
# Only GOOGLE_* and JWT_SECRET are required — everything else is optional
# and unlocks an extra integration when set.

# REQUIRED — Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# REQUIRED — public URL where the app runs (no trailing slash)
# Local dev: http://localhost:3000   Production: https://timesync.yourcompany.com
BASE_URL=http://localhost:3000

# REQUIRED — random string for session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me

# Recommended: restrict sign-in to your company domain
ALLOWED_DOMAIN=

# ── OPTIONAL: AI meeting memory & briefs (set ONE of these) ──
# Gemini API key (free) from https://aistudio.google.com → "Get API key"
# Note: the company Gemini Pro chat subscription is NOT an API key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# ...or an Anthropic key from https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OPTIONAL: Slack notifications, weekly digest, action nudges ──
# Create at https://api.slack.com/apps → Incoming Webhooks → pick a channel
SLACK_WEBHOOK_URL=
# Cron schedules (server time): digest Mondays 9am, nudges weekdays 9am
DIGEST_CRON=0 9 * * 1
NUDGE_CRON=0 9 * * 1-5

# ── OPTIONAL: dashboard ingest endpoint (Today page connectors) ──
# Lets external automations (Zapier, Google Apps Script, cron pollers,
# future Slack/Gmail/Zendesk connectors) push work items into the Today
# dashboard. Items are classified by the local rules engine — no AI needed.
# Generate a token:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Then POST JSON to {BASE_URL}/api/ingest?token=...
#   { "user": "you@company.com", "src": "zendesk", "from": "Ticket #123",
#     "text": "Customer cannot log in — assigned to you", "link": "https://..." }
INGEST_TOKEN=

# Misc
PORT=3000
DB_PATH=./db.json
